---
type Material = { type?: string; label?: string; url: string };
type Speaker = { name: string; url?: string };
type Talk = {
  title: string;
  speakers?: Speaker[];
  description?: string;
  slidesUrl?: string;
  videoUrl?: string;
  materials?: Material[];
};

interface Props {
  event: any;
  status?: 'next' | 'upcoming' | 'past';
}
const { event, status = 'past' } = Astro.props;

const formatDateLong = (d: string | Date) =>
  new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });

const formatDateParts = (d: string | Date) => {
  const date = new Date(d);
  return {
    day: date.toLocaleDateString('en-GB', { day: '2-digit' }),
    month: date.toLocaleDateString('en-GB', { month: 'short' }).toUpperCase(),
    weekday: date.toLocaleDateString('en-GB', { weekday: 'short' }).toUpperCase(),
  };
};

const allMaterials = (t: Talk): Material[] => {
  const out: Material[] = [];
  if (t.slidesUrl) out.push({ type: 'slides', url: t.slidesUrl });
  if (t.videoUrl) out.push({ type: 'video', url: t.videoUrl });
  if (Array.isArray(t.materials)) {
    for (const m of t.materials) {
      if (!m?.url) continue;
      if (!out.some((x) => x.url === m.url)) out.push(m);
    }
  }
  return out;
};

const glyph = (type?: string) => {
  switch ((type || '').toLowerCase()) {
    case 'slides': return '◆';
    case 'video': case 'recording': return '▶';
    case 'code': case 'repo': case 'github': return '{ }';
    case 'demo': return '✦';
    case 'notes': return '✎';
    default: return '↗';
  }
};

const labelFor = (m: Material) => m.label || m.type || 'link';

const Body = event.Content;
const hasBody = (event.rawContent?.() || '').trim().length > 0;
const img = event.frontmatter.image;
const parts = formatDateParts(event.frontmatter.date);

const statusLabel = status === 'next' ? 'NEXT UP' : status === 'upcoming' ? 'UPCOMING' : null;
const statusTone = status === 'next'
  ? 'bg-accent/15 text-accent border-accent/40'
  : 'border-cream/25 text-cream/70';
---

<article
  id={`event-${event.frontmatter.number}`}
  class="lg:min-h-screen flex flex-col justify-center px-6 py-10 md:px-10 md:py-12 lg:px-14 lg:py-14 border-b border-cream/10 last:border-b-0"
>
  <div class="w-full md:grid md:grid-cols-[1fr_auto] md:gap-10 md:items-start">

    <!-- Left column: content -->
    <div class="min-w-0">
      <!-- Header row: #NNN + status + (mobile-only inline date) -->
      <div class="flex items-start justify-between gap-4 mb-5">
        <div class="flex items-center gap-3 flex-wrap">
          <div class="text-xs text-cream/40 font-bold tracking-widest">
            #{String(event.frontmatter.number).padStart(3, '0')}
          </div>
          {statusLabel && (
            <span class={`inline-flex items-center px-2 py-0.5 text-[10px] tracking-widest border rounded-sm ${statusTone}`}>
              {status === 'next' && (
                <span class="inline-block w-1.5 h-1.5 rounded-full bg-accent mr-1.5 animate-pulse"></span>
              )}
              {statusLabel}
            </span>
          )}
        </div>
        <!-- Mobile-only inline date (md+ uses the right-column date chip) -->
        <div class="md:hidden flex items-baseline gap-2 text-right shrink-0">
          <div class="text-[10px] tracking-widest text-cream/40">{parts.weekday}</div>
          <div class="text-xl font-bold leading-none">{parts.day}</div>
          <div class="text-xs tracking-widest text-accent">{parts.month}</div>
        </div>
      </div>

      {img && (
        <div class="mb-5 overflow-hidden rounded-sm border border-cream/10">
          <img src={img} alt={event.frontmatter.title} class="w-full h-40 lg:h-48 object-cover" loading="lazy" />
        </div>
      )}

      <h2 class="text-2xl md:text-3xl lg:text-3xl font-bold leading-tight">{event.frontmatter.title}</h2>

      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs lg:text-sm text-cream/60 mt-2">
        <span>{formatDateLong(event.frontmatter.date)}</span>
        {event.frontmatter.location && (
          <>
            <span class="text-cream/25">·</span>
            {event.frontmatter.locationUrl ? (
              <a href={event.frontmatter.locationUrl} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">{event.frontmatter.location}</a>
            ) : (
              <span>{event.frontmatter.location}</span>
            )}
          </>
        )}
        {event.frontmatter.meetupUrl && (
          <>
            <span class="text-cream/25">·</span>
            <a href={event.frontmatter.meetupUrl} target="_blank" rel="noopener noreferrer" class="text-accent hover:text-cream transition-colors">meetup ↗</a>
          </>
        )}
      </div>

      {event.frontmatter.description && (
        <p class="text-sm lg:text-base text-cream/75 mt-4">{event.frontmatter.description}</p>
      )}

      {event.frontmatter.talks && event.frontmatter.talks.length > 0 && (
        <div class="mt-6 space-y-4">
          {event.frontmatter.talks.map((talk: Talk) => {
            const materials = allMaterials(talk);
            return (
              <div class="border-l-2 border-cream/15 hover:border-accent/50 transition-colors pl-4 py-0.5">
                <div class="text-sm lg:text-base font-semibold text-cream">{talk.title}</div>
                {talk.speakers && talk.speakers.length > 0 && (
                  <div class="text-xs text-cream/55 mt-0.5">
                    by {talk.speakers.map((s, i) => (
                      <>
                        {i > 0 && ', '}
                        {s.url ? (
                          <a href={s.url} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">{s.name}</a>
                        ) : s.name}
                      </>
                    ))}
                  </div>
                )}
                {talk.description && (
                  <p class="text-xs lg:text-sm text-cream/65 mt-2 leading-relaxed">{talk.description}</p>
                )}
                {materials.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-2.5">
                    {materials.map((m) => (
                      <a href={m.url} target="_blank" rel="noopener noreferrer"
                         class="inline-flex items-center gap-1 px-2 py-0.5 text-[11px] border border-cream/20 text-cream/80 hover:text-accent hover:border-accent rounded-sm transition-colors">
                        <span aria-hidden="true">{glyph(m.type)}</span>
                        <span>{labelFor(m)}</span>
                      </a>
                    ))}
                  </div>
                )}
              </div>
            );
          })}
        </div>
      )}

      {hasBody && (
        <div class="event-body mt-5 text-sm">
          <Body />
        </div>
      )}
    </div>

    <!-- Right column: date (md+ only) -->
    <aside class="hidden md:flex md:flex-col md:items-end md:text-right md:shrink-0">
      <div class="text-[10px] tracking-widest text-cream/45">{parts.weekday}</div>
      <div class="text-3xl lg:text-4xl font-bold leading-none mt-1">{parts.day}</div>
      <div class="text-xs tracking-widest text-accent mt-1">{parts.month}</div>
    </aside>

  </div>
</article>
